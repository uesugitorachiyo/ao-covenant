{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "AO Covenant Release Diff",
          "informationUri": "https://github.com/uesugitorachiyo/ao-covenant",
          "rules": [
            {
              "id": "RELEASE_DIFF_METADATA",
              "shortDescription": {
                "text": "Release metadata changed"
              },
              "help": {
                "text": ""
              }
            },
            {
              "id": "RELEASE_DIFF_ARTIFACT",
              "shortDescription": {
                "text": "Release artifact changed"
              },
              "help": {
                "text": ""
              }
            },
            {
              "id": "RELEASE_DIFF_SUPPLEMENTAL_ARTIFACT",
              "shortDescription": {
                "text": "Release supplemental artifact changed"
              },
              "help": {
                "text": ""
              }
            },
            {
              "id": "RELEASE_DIFF_SIGNATURE",
              "shortDescription": {
                "text": "Release signature changed"
              },
              "help": {
                "text": ""
              }
            },
            {
              "id": "RELEASE_DIFF_PROBLEM",
              "shortDescription": {
                "text": "Release problem changed"
              },
              "help": {
                "text": ""
              }
            }
          ]
        }
      },
      "results": []
    }
  ]
}
