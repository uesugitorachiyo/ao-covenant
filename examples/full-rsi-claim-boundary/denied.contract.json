{
  "schema_version": "covenant.contract.v1",
  "objective": "Attempt to publish a full autonomous self-mutating RSI claim without approval evidence.",
  "workspace": {
    "root": ".",
    "reads": [
      "brief.md"
    ],
    "writes": []
  },
  "obligations": [
    {
      "id": "obl_rsi_claim_boundary",
      "text": "Do not publish full autonomous self-mutating RSI without mutation authority, rollback, and live self-change evidence.",
      "required": true
    }
  ],
  "tasks": [
    {
      "id": "publish_rsi_claim",
      "kind": "scripted",
      "adapter": "process",
      "depends_on": [],
      "obligations": [
        "obl_rsi_claim_boundary"
      ],
      "timeout_seconds": 60,
      "declared_side_effects": [
        {
          "type": "file.read",
          "resource": "brief.md"
        },
        {
          "type": "claim.publish",
          "resource": "full-autonomous-self-mutating-rsi"
        }
      ]
    }
  ],
  "policy": {
    "mode": "strict"
  },
  "evaluator": {
    "required_obligations": [
      "obl_rsi_claim_boundary"
    ]
  }
}
