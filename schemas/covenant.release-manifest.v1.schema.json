{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.release-manifest.v1",
  "title": "AO Covenant Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "version", "commit", "date", "artifacts"],
  "properties": {
    "schema_version": { "const": "covenant.release-manifest.v1" },
    "version": { "type": "string", "minLength": 1 },
    "commit": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "target", "path", "sha256", "size_bytes"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "required": ["os", "arch"],
            "properties": {
              "os": { "type": "string", "minLength": 1 },
              "arch": { "type": "string", "minLength": 1 }
            }
          },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 1 },
          "attestations": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "path", "sha256", "size_bytes"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "kind": { "type": "string", "minLength": 1 },
                "path": { "type": "string", "minLength": 1 },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "size_bytes": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "supplemental_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "name", "path", "sha256", "size_bytes"],
        "properties": {
          "kind": { "enum": ["sbom", "provenance"] },
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
