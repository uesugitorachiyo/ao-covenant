{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.release-verify-result.v1",
  "title": "AO Covenant Release Verify Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "verified",
    "manifest_path",
    "checksums_path",
    "artifact_count",
    "problems",
    "artifacts",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "covenant.release-verify-result.v1"
    },
    "verified": {
      "type": "boolean"
    },
    "manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "checksums_path": {
      "type": "string",
      "minLength": 1
    },
    "signature_path": {
      "type": "string",
      "minLength": 1
    },
    "artifact_count": {
      "type": "integer",
      "minimum": 0
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "public_key_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "target",
          "path",
          "verified",
          "path_valid",
          "digest_verified",
          "size_verified",
          "checksum_verified",
          "metadata_verified",
          "host_metadata_checked",
          "sha256",
          "size_bytes",
          "actual_sha256",
          "actual_size_bytes",
          "problems"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "required": ["os", "arch"],
            "properties": {
              "os": {
                "type": "string",
                "minLength": 1
              },
              "arch": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "verified": {
            "type": "boolean"
          },
          "path_valid": {
            "type": "boolean"
          },
          "digest_verified": {
            "type": "boolean"
          },
          "size_verified": {
            "type": "boolean"
          },
          "checksum_verified": {
            "type": "boolean"
          },
          "metadata_verified": {
            "type": "boolean"
          },
          "host_metadata_checked": {
            "type": "boolean"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "actual_sha256": {
            "type": "string"
          },
          "actual_size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "attestations": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "path",
                "verified",
                "path_valid",
                "digest_verified",
                "size_verified",
                "checksum_verified",
                "sha256",
                "size_bytes",
                "actual_sha256",
                "actual_size_bytes",
                "problems"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "kind": {
                  "type": "string",
                  "minLength": 1
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "verified": {
                  "type": "boolean"
                },
                "path_valid": {
                  "type": "boolean"
                },
                "digest_verified": {
                  "type": "boolean"
                },
                "size_verified": {
                  "type": "boolean"
                },
                "checksum_verified": {
                  "type": "boolean"
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                },
                "size_bytes": {
                  "type": "integer",
                  "minimum": 0
                },
                "actual_sha256": {
                  "type": "string"
                },
                "actual_size_bytes": {
                  "type": "integer",
                  "minimum": 0
                },
                "problems": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          },
          "problems": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "supplemental_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "name",
          "path",
          "verified",
          "path_valid",
          "digest_verified",
          "size_verified",
          "checksum_verified",
          "sha256",
          "size_bytes",
          "actual_sha256",
          "actual_size_bytes",
          "problems"
        ],
        "properties": {
          "kind": { "enum": ["sbom", "provenance"] },
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "verified": { "type": "boolean" },
          "path_valid": { "type": "boolean" },
          "digest_verified": { "type": "boolean" },
          "size_verified": { "type": "boolean" },
          "checksum_verified": { "type": "boolean" },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "actual_sha256": { "type": "string" },
          "actual_size_bytes": { "type": "integer", "minimum": 0 },
          "problems": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "commit", "date", "signature_verified", "artifacts"],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "minLength": 1
        },
        "public_key_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "signature_verified": {
          "type": "boolean"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "target", "verification_status", "metadata_verified"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "target": {
                "type": "object",
                "additionalProperties": false,
                "required": ["os", "arch"],
                "properties": {
                  "os": {
                    "type": "string",
                    "minLength": 1
                  },
                  "arch": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "verification_status": {
                "enum": ["verified", "invalid"]
              },
              "metadata_verified": {
                "type": "boolean"
              },
              "attestations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "path", "verification_status", "sha256", "size_bytes"],
                  "properties": {
                    "kind": {
                      "type": "string",
                      "minLength": 1
                    },
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "verification_status": {
                      "enum": ["verified", "invalid"]
                    },
                    "sha256": {
                      "type": "string",
                      "pattern": "^[a-f0-9]{64}$"
                    },
                    "size_bytes": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                }
              },
              "binary_metadata": {
                "type": "object",
                "additionalProperties": false,
                "required": ["schema_version", "version", "commit", "date", "go_version", "os", "arch"],
                "properties": {
                  "schema_version": { "const": "covenant.version-result.v1" },
                  "version": { "type": "string", "minLength": 1 },
                  "commit": { "type": "string", "minLength": 1 },
                  "date": { "type": "string", "minLength": 1 },
                  "go_version": { "type": "string", "minLength": 1 },
                  "os": { "type": "string", "minLength": 1 },
                  "arch": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        "supplemental_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "name", "path", "verification_status", "sha256", "size_bytes"],
            "properties": {
              "kind": { "enum": ["sbom", "provenance"] },
              "name": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "verification_status": { "enum": ["verified", "invalid"] },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "size_bytes": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
