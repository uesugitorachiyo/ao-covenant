{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.registry-compatibility-ci-handoff.v1",
  "title": "AO Covenant Registry Compatibility CI Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "handoff_id",
    "owner_repo",
    "status",
    "source_recommendation_rank",
    "source_recommendation_task",
    "safety_gate",
    "ci_intent",
    "producer_consumer_pairs",
    "pair_count",
    "no_promotion_requested",
    "provider_calls_allowed",
    "credential_use_allowed",
    "release_or_publish_allowed",
    "claims_authority_advance",
    "policy_or_auth_widening",
    "hidden_instruction_change",
    "direct_main_mutation",
    "rsi_remains_denied"
  ],
  "properties": {
    "schema_version": {
      "const": "covenant.registry-compatibility-ci-handoff.v1"
    },
    "handoff_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "owner_repo": {
      "const": "ao-covenant"
    },
    "status": {
      "const": "planning_only"
    },
    "source_recommendation_rank": {
      "const": 24
    },
    "source_recommendation_task": {
      "const": "Add registry compatibility CI handoff prompt"
    },
    "safety_gate": {
      "const": "planning_only_no_provider_no_release"
    },
    "ci_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "required_inputs",
        "required_consumer_checks",
        "failure_policy"
      ],
      "properties": {
        "mode": {
          "const": "handoff_prompt_only"
        },
        "required_inputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_consumer_checks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "failure_policy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "producer_consumer_pairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contract_id",
          "owner_repo",
          "producer_repos",
          "consumer_repos",
          "required_evidence"
        ],
        "properties": {
          "contract_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9.-]*\\.v[0-9]+$"
          },
          "owner_repo": {
            "const": "ao-covenant"
          },
          "producer_repos": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^ao[0-9a-z-]*$"
            }
          },
          "consumer_repos": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^ao[0-9a-z-]*$"
            }
          },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "pair_count": {
      "type": "integer",
      "minimum": 1
    },
    "no_promotion_requested": {
      "const": true
    },
    "provider_calls_allowed": {
      "const": false
    },
    "credential_use_allowed": {
      "const": false
    },
    "release_or_publish_allowed": {
      "const": false
    },
    "claims_authority_advance": {
      "const": false
    },
    "policy_or_auth_widening": {
      "const": false
    },
    "hidden_instruction_change": {
      "const": false
    },
    "direct_main_mutation": {
      "const": false
    },
    "rsi_remains_denied": {
      "const": true
    }
  }
}
