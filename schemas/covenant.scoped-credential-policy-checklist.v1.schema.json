{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.scoped-credential-policy-checklist.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "scope",
    "check_count",
    "checks",
    "credential_value_inspection_allowed",
    "credential_values_inspected",
    "credential_values_stored",
    "requires_credential_material",
    "safe_to_execute",
    "executes_work",
    "approves_work",
    "mutates_repositories",
    "provider_calls_allowed",
    "release_or_publish_allowed",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "properties": {
    "schema_version": { "const": "covenant.scoped-credential-policy-checklist.v1" },
    "status": { "const": "ready" },
    "scope": { "const": "metadata_and_operator_checklist_only" },
    "check_count": { "type": "integer", "minimum": 5 },
    "checks": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "requirement",
          "evidence",
          "requires_credential_value",
          "allows_credential_capture"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "const": "passed" },
          "requirement": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "requires_credential_value": { "const": false },
          "allows_credential_capture": { "const": false }
        }
      }
    },
    "credential_value_inspection_allowed": { "const": false },
    "credential_values_inspected": { "const": false },
    "credential_values_stored": { "const": false },
    "requires_credential_material": { "const": false },
    "safe_to_execute": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "mutates_repositories": { "const": false },
    "provider_calls_allowed": { "const": false },
    "release_or_publish_allowed": { "const": false },
    "claims_authority_advance": { "const": false },
    "rsi_remains_denied": { "const": true }
  }
}
