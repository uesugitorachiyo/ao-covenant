{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.contract-ownership-matrix.v1",
  "title": "AO Covenant Contract Ownership Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "matrix_id",
    "owner_repo",
    "status",
    "source_recommendation_rank",
    "safety_gate",
    "entries",
    "entry_count",
    "no_promotion_requested",
    "provider_calls_allowed",
    "credential_use_allowed",
    "release_or_publish_allowed",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "properties": {
    "schema_version": {
      "const": "covenant.contract-ownership-matrix.v1"
    },
    "matrix_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "owner_repo": {
      "const": "ao-covenant"
    },
    "status": {
      "const": "published_fixture"
    },
    "source_recommendation_rank": {
      "const": 4
    },
    "source_recommendation_task": {
      "const": "Publish Covenant-owned contract ownership matrix fixture"
    },
    "safety_gate": {
      "const": "planning_only_no_provider_no_release"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contract_id",
          "owner_repo",
          "owner_component",
          "stability",
          "lifecycle",
          "producer_repos",
          "consumer_repos",
          "consumer_test_refs",
          "policy_authority_required",
          "compatibility_gate_required"
        ],
        "properties": {
          "contract_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9.-]*\\.v[0-9]+$"
          },
          "owner_repo": {
            "type": "string",
            "pattern": "^ao[0-9a-z-]*$"
          },
          "owner_component": {
            "type": "string",
            "minLength": 1
          },
          "stability": {
            "enum": ["stable", "experimental", "deprecated"]
          },
          "lifecycle": {
            "enum": ["active", "planned", "deprecated"]
          },
          "producer_repos": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^ao[0-9a-z-]*$"
            }
          },
          "consumer_repos": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^ao[0-9a-z-]*$"
            }
          },
          "consumer_test_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9._/:-]+$"
            }
          },
          "policy_authority_required": {
            "type": "boolean"
          },
          "compatibility_gate_required": {
            "const": true
          }
        }
      }
    },
    "entry_count": {
      "type": "integer",
      "minimum": 1
    },
    "no_promotion_requested": {
      "const": true
    },
    "provider_calls_allowed": {
      "const": false
    },
    "credential_use_allowed": {
      "const": false
    },
    "release_or_publish_allowed": {
      "const": false
    },
    "claims_authority_advance": {
      "const": false
    },
    "rsi_remains_denied": {
      "const": true
    }
  }
}
