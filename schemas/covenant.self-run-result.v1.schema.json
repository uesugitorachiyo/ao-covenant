{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.self-run-result.v1",
  "title": "AO Covenant Self-Run Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_path",
    "contract_digest",
    "contract_digest_file",
    "run_id",
    "run_dir",
    "ledger_path",
    "evidence_pack_path",
    "verified",
    "failure_count"
  ],
  "properties": {
    "schema_version": { "const": "covenant.self-run-result.v1" },
    "contract_path": { "type": "string", "minLength": 1 },
    "contract_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "contract_digest_file": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "run_dir": { "type": "string", "minLength": 1 },
    "ledger_path": { "type": "string", "minLength": 1 },
    "evidence_pack_path": { "type": "string", "minLength": 1 },
    "verified": { "type": "boolean" },
    "failure_count": { "type": "integer", "minimum": 0 }
  }
}
