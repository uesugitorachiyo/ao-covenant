{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.low-risk-code-live-policy.v1",
  "title": "AO Covenant Low Risk Code Live Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "approval_state",
    "approver_identity",
    "issued_at",
    "expires_at",
    "consumed",
    "mutation_class",
    "safe_to_request",
    "safe_to_execute",
    "candidate_scope",
    "scope_digest",
    "authority_boundaries",
    "operator_note"
  ],
  "properties": {
    "schema_version": { "const": "covenant.low-risk-code-live-policy.v1" },
    "policy_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "approval_state": { "enum": ["approved", "blocked", "denied"] },
    "approver_identity": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "consumed": { "type": "boolean" },
    "mutation_class": { "const": "low_risk_code" },
    "safe_to_request": { "type": "boolean" },
    "safe_to_execute": { "const": false },
    "candidate_scope": { "$ref": "#/$defs/candidate_scope" },
    "scope_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value", "covers"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "covers": {
          "type": "array",
          "minItems": 1,
          "contains": { "const": "candidate_scope" },
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "authority_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_scope",
        "class_bound",
        "digest_bound",
        "single_use",
        "single_repo",
        "single_branch",
        "live_mutation_grant",
        "multi_repo_mutation_allowed",
        "complex_repo_mutation_allowed",
        "fully_unsupervised_complex_mutation_allowed",
        "provider_calls_allowed",
        "release_or_publish_allowed"
      ],
      "properties": {
        "exact_scope": { "const": true },
        "class_bound": { "const": true },
        "digest_bound": { "const": true },
        "single_use": { "const": true },
        "single_repo": { "const": true },
        "single_branch": { "const": true },
        "live_mutation_grant": { "const": false },
        "multi_repo_mutation_allowed": { "const": false },
        "complex_repo_mutation_allowed": { "const": false },
        "fully_unsupervised_complex_mutation_allowed": { "const": false },
        "provider_calls_allowed": { "const": false },
        "release_or_publish_allowed": { "const": false }
      }
    },
    "operator_note": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "relative_path": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._/-]+$"
    },
    "candidate_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dry_run_chain",
        "repo",
        "base_branch",
        "proposed_branch",
        "intent",
        "file_allowlist",
        "command_allowlist",
        "rollback_plan"
      ],
      "properties": {
        "dry_run_chain": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "$ref": "#/$defs/relative_path" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "repo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "remote"],
          "properties": {
            "id": { "const": "ao-atlas" },
            "remote": { "const": "uesugitorachiyo/ao-atlas" }
          }
        },
        "base_branch": { "const": "main" },
        "proposed_branch": {
          "type": "string",
          "pattern": "^codex/[A-Za-z0-9._-]+$"
        },
        "intent": { "type": "string", "minLength": 1 },
        "file_allowlist": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "$ref": "#/$defs/relative_path" }
        },
        "command_allowlist": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "rollback_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "strategy", "scope"],
          "properties": {
            "required": { "const": true },
            "strategy": { "type": "string", "minLength": 1 },
            "scope": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "items": { "$ref": "#/$defs/relative_path" }
            }
          }
        }
      }
    }
  }
}
