{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.version-result.v1",
  "title": "AO Covenant Version Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "version", "commit", "date", "go_version", "os", "arch"],
  "properties": {
    "schema_version": { "const": "covenant.version-result.v1" },
    "version": { "type": "string", "minLength": 1 },
    "commit": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "minLength": 1 },
    "go_version": { "type": "string", "minLength": 1 },
    "os": { "type": "string", "minLength": 1 },
    "arch": { "type": "string", "minLength": 1 }
  }
}
