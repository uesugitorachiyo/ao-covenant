{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.contract.v1",
  "title": "AO Covenant Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "objective",
    "workspace",
    "obligations",
    "tasks",
    "policy",
    "evaluator"
  ],
  "properties": {
    "schema_version": { "const": "covenant.contract.v1" },
    "objective": { "type": "string", "minLength": 1 },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "reads", "writes"],
      "properties": {
        "root": { "$ref": "#/$defs/workspace_path" },
        "reads": {
          "type": "array",
          "items": { "$ref": "#/$defs/workspace_path" }
        },
        "writes": {
          "type": "array",
          "items": { "$ref": "#/$defs/workspace_path" }
        }
      }
    },
    "obligations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "required"],
        "properties": {
          "id": { "$ref": "#/$defs/portable_id" },
          "text": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "covenant.task.v1" }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["strict"] }
      }
    },
    "approvals": {
      "type": "array",
      "items": { "$ref": "covenant.approval-ticket.v1" }
    },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_obligations"],
      "properties": {
        "required_obligations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/portable_id" }
        }
      }
    }
  },
  "$defs": {
    "portable_id": {
      "type": "string",
      "pattern": "^(?!con$|prn$|aux$|nul$|com[1-9]$|lpt[1-9]$)[a-z0-9_-]+$"
    },
    "workspace_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!\\.\\.($|/))(?!.*(^|/)\\.\\.(/|$)).+$"
    }
  }
}
