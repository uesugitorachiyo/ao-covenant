{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.evidence-bundle.v1",
  "title": "AO Covenant Evidence Bundle Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "contract_digest",
    "ledger_digest",
    "verification",
    "entries"
  ],
  "properties": {
    "schema_version": { "const": "covenant.evidence-bundle.v1" },
    "run_id": {
      "type": "string",
      "pattern": "^(?!con$|prn$|aux$|nul$|com[1-9]$|lpt[1-9]$)[a-z0-9_-]+$"
    },
    "contract_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "ledger_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified",
        "event_count",
        "artifact_count",
        "input_snapshot_count",
        "failure_count"
      ],
      "properties": {
        "verified": { "type": "boolean" },
        "event_count": { "type": "integer", "minimum": 0 },
        "artifact_count": { "type": "integer", "minimum": 0 },
        "input_snapshot_count": { "type": "integer", "minimum": 0 },
        "failure_count": { "type": "integer", "minimum": 0 }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "source", "sha256", "size_bytes"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!\\.\\.($|/))(?!.*(^|/)\\.\\.(/|$)).+$"
          },
          "source": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
