{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.evidence-pack.v1",
  "title": "AO Covenant Evidence Pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "contract_digest", "ledger_digest", "run_status", "artifact_manifest", "input_snapshots", "policy_decisions", "failures", "closure_matrix"],
  "properties": {
    "schema_version": { "const": "covenant.evidence-pack.v1" },
    "run_id": {
      "type": "string",
      "pattern": "^(?!con$|prn$|aux$|nul$|com[1-9]$|lpt[1-9]$)[a-z0-9_-]+$"
    },
    "contract_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "ledger_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "run_status": { "enum": ["success", "failed"] },
    "artifact_manifest": {
      "type": "array",
      "items": { "$ref": "covenant.artifact-ref.v1" }
    },
    "input_snapshots": {
      "type": "array",
      "items": { "$ref": "covenant.input-snapshot.v1" }
    },
    "policy_decisions": {
      "type": "array",
      "items": { "$ref": "covenant.policy-decision.v1" }
    },
    "failures": {
      "type": "array",
      "items": { "$ref": "covenant.failure.v1" }
    },
    "closure_matrix": {
      "$ref": "covenant.closure-matrix.v1"
    }
  }
}
