{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.input-snapshot.v1",
  "title": "AO Covenant Input Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "snapshot_id", "source_path", "snapshot_path", "digest", "media_type"],
  "properties": {
    "schema_version": { "const": "covenant.input-snapshot.v1" },
    "snapshot_id": {
      "type": "string",
      "pattern": "^(?!con$|prn$|aux$|nul$|com[1-9]$|lpt[1-9]$)[a-z0-9_-]+$"
    },
    "source_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!\\.\\.($|/))(?!.*(^|/)\\.\\.(/|$)).+$"
    },
    "snapshot_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!\\.\\.($|/))(?!.*(^|/)\\.\\.(/|$)).+$"
    },
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "media_type": { "type": "string", "minLength": 1 }
  }
}
