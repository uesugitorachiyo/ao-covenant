{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.policy-spine-result.v1",
  "title": "AO Covenant Policy Spine Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "stack", "status", "scope", "responsibilities", "out_of_bounds"],
  "properties": {
    "schema_version": { "const": "covenant.policy-spine-result.v1" },
    "stack": { "const": "ao2-first" },
    "status": { "enum": ["ready"] },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active_repositories", "replaced_by"],
      "properties": {
        "active_repositories": {
          "type": "array",
          "minItems": 6,
          "uniqueItems": true,
          "contains": { "const": "ao-covenant" },
          "items": {
            "enum": [
              "ao2",
              "ao2-control-plane",
              "ao-foundry",
              "ao-forge",
              "ao-command",
              "ao-covenant"
            ]
          }
        },
        "replaced_by": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": [
              "ao2",
              "ao2-control-plane"
            ]
          }
        }
      }
    },
    "responsibilities": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "owner", "gates"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "owner": {
            "enum": [
              "ao2",
              "ao2-control-plane",
              "ao-foundry",
              "ao-forge",
              "ao-command",
              "ao-covenant"
            ]
          },
          "gates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "out_of_bounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
