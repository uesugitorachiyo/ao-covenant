{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.run-result.v1",
  "title": "AO Covenant Run Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "run_dir", "ledger_path", "evidence_pack_path"],
  "properties": {
    "schema_version": { "const": "covenant.run-result.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "run_dir": { "type": "string", "minLength": 1 },
    "ledger_path": { "type": "string", "minLength": 1 },
    "evidence_pack_path": { "type": "string", "minLength": 1 }
  }
}
