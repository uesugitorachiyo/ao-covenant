{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.policy-explain-result.v1",
  "title": "AO Covenant Policy Explain Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_explanations"],
  "properties": {
    "schema_version": { "const": "covenant.policy-explain-result.v1" },
    "policy_explanations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision_id", "task_id", "effect_type", "resource", "decision", "reason", "summary", "detail"],
        "properties": {
          "decision_id": { "type": "string", "minLength": 1 },
          "task_id": { "type": "string", "minLength": 1 },
          "effect_type": { "enum": ["file.write", "file.read", "process.spawn", "network.request", "claim.publish"] },
          "resource": { "type": "string", "minLength": 1 },
          "decision": { "enum": ["allow", "deny"] },
          "reason": { "type": "string", "minLength": 1 },
          "approval_ticket_id": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "detail": { "type": "string", "minLength": 1 },
          "operator_action": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
