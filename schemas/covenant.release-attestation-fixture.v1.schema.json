{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.release-attestation-fixture.v1",
  "title": "AO Covenant Release Attestation Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "description",
    "expected",
    "release",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "const": "covenant.release-attestation-fixture.v1"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "expected": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "repo",
        "manifest",
        "artifact",
        "target",
        "public_only"
      ],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+.*$"
        },
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "manifest": {
          "const": "manifest.json"
        },
        "artifact": {
          "type": "string",
          "minLength": 1,
          "pattern": "^ao-covenant_[A-Za-z0-9._-]+$"
        },
        "target": {
          "type": "string",
          "pattern": "^[a-z0-9]+/[a-z0-9]+$"
        },
        "public_only": {
          "const": true
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "artifact", "command", "required"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["manifest", "platform-binary"]
          },
          "artifact": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1,
            "pattern": "^gh attestation verify .+ --repo [A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
          },
          "required": {
            "const": true
          }
        }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "failing_check",
        "consumer_action",
        "sensitive_omitted"
      ],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "failing_check": {
          "type": "string",
          "enum": ["manifest", "platform-binary"]
        },
        "consumer_action": {
          "type": "string",
          "minLength": 1
        },
        "sensitive_omitted": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "expected": { "const": "pass" } },
        "required": ["expected"]
      },
      "then": {
        "not": { "required": ["failure"] }
      }
    },
    {
      "if": {
        "properties": { "expected": { "const": "fail" } },
        "required": ["expected"]
      },
      "then": {
        "required": ["failure"]
      }
    }
  ]
}
