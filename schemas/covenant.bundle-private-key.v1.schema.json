{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "covenant.bundle-private-key.v1",
  "title": "AO Covenant Bundle Private Key v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "algorithm", "public_key", "private_key"],
  "properties": {
    "schema_version": { "const": "covenant.bundle-private-key.v1" },
    "algorithm": { "const": "ed25519" },
    "public_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/]+={0,2}$",
      "minLength": 44,
      "maxLength": 44
    },
    "private_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/]+={0,2}$",
      "minLength": 88,
      "maxLength": 88
    }
  }
}
